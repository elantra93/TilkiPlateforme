# Copier ce fichier en .env à la racine du projet et renseigner les valeurs.
# Le fichier .env ne doit JAMAIS être commité (il est dans .gitignore).

# ── Base de données ───────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASS=

# ── Application ───────────────────────────────────────────────────────────────
# APP_ENV=production   # production | development

# ── Mail SMTP ─────────────────────────────────────────────────────────────────
# MAIL_FROM=noreply@tilki.digital
# MAIL_SMTP_HOST=smtp.hostinger.com
# MAIL_SMTP_PORT=587
# MAIL_SMTP_USER=noreply@tilki.digital
MAIL_SMTP_PASS=
# MAIL_SMTP_SECURE=tls

# ── Tally (webhooks & formulaires) ───────────────────────────────────────────
TALLY_SECRET=
TALLY_CLAIM_FORM_URL=

# ── Tally — Formulaires de devis (laisser vide pour masquer le bouton) ───────
TALLY_DEVIS_AUTO=
TALLY_DEVIS_MOTO=
TALLY_DEVIS_VOYAGE=
TALLY_DEVIS_SANTE=
TALLY_DEVIS_MRH=
TALLY_DEVIS_MRP=
TALLY_DEVIS_RC=
